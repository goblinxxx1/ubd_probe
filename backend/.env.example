# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored and must never be committed.

# Working database (app runtime)
DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/ubd

# Test database — MUST be a separate schema, tests drop/recreate tables here
TEST_DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/ubd_test

# Auth
JWT_SECRET=change-me-in-production
CRAWLER_API_KEY=change-me-crawler-key

# Seeded initial super_admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-admin-password
