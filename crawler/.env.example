INTERNAL_API_URL=http://localhost:8000
CRAWLER_API_KEY=change-me-crawler-key
EXTRACTOR=heuristic
ACTIVE_DISCOVERY=false
REQUEST_TIMEOUT=20
MIN_DELAY_SECONDS=2
# Bot accounts (never commit real values): "user1:pass1,user2:pass2"
INSTAGRAM_ACCOUNTS=
FACEBOOK_ACCOUNTS=
# Optional per-platform proxy: "instagram=http://...,facebook=http://..."
PROXIES=

# --- Active search discovery (Track A) --- toggle with ACTIVE_DISCOVERY above
SEARCH_PROVIDERS=duckduckgo
SEARCH_RESULTS_PER_KEYWORD=7
# Base delay (seconds) between real search network calls; long on purpose — speed
# is not important, avoiding IP blocks is. Cache hits do not sleep.
SEARCH_MIN_DELAY=45
# --- Anti-throttle (single IP, no proxies) ---
# Backend rotation pool: one endpoint per query, round-robin. UA-relevant web
# engines only (2x Google, 2x Bing, Brave). Dropped mojeek/wikipedia/grokipedia/yandex.
SEARCH_BACKENDS=google,startpage,duckduckgo,yahoo,brave
# Persistent state file (cooldown + keyword cache + rotation cursor + global backoff).
# Put on a Docker volume so it survives container restarts.
SEARCH_STATE_PATH=/data/search_state.json
SEARCH_CACHE_TTL_HOURS=168
SEARCH_JITTER=0.5
SEARCH_BACKEND_COOLDOWN_BASE_SECONDS=300
SEARCH_BACKEND_COOLDOWN_CAP_SECONDS=21600
SEARCH_GLOBAL_BACKOFF_HOURS=6
SEARCH_BUDGET=0
# Max page fetches per pass for active-search offer harvesting (0 disables harvesting)
ACTIVE_FETCH_BUDGET=20
# SearXNG (Track B): enable by adding `searxng` to SEARCH_PROVIDERS above, e.g.
#   SEARCH_PROVIDERS=duckduckgo,searxng   (or just: searxng)
SEARXNG_URL=http://searxng:8080

# Freshness: published crawler offers not re-confirmed by a passive re-crawl within this
# many days are marked expired (drops off the public site). Signal is re-crawl only.
FRESHNESS_TTL_DAYS=30
# Comma-separated search phrases:
SEARCH_KEYWORDS=знижки для учасників бойових дій, пільги УБД Україна, знижки ветеранам війни, знижки для військовослужбовців ЗСУ, спецпропозиції для ветеранів АТО ООС, знижки для сімей учасників бойових дій, пільги родинам військовослужбовців, пільги сім'ям загиблих військових, знижки родинам загиблих захисників, знижки для осіб з інвалідністю внаслідок війни, пільги ветеранам з інвалідністю, знижки для працівників ДСНС, пільги рятувальникам ДСНС, знижки для поліцейських, пільги працівникам Національної поліції, знижки для захисників України, безкоштовні послуги для військових та їхніх родин, знижка для УБД санаторій, безкоштовне лікування військовослужбовців, відпочинок для членів сімей загиблих захисників, оздоровлення дітей учасників бойових дій, пільги на проживання для військових, реабілітація для учасників бойових дій готель, знижка для військових кафе, безкоштовна кава для ЗСУ, знижка УБД ресторан, меню для військовослужбовців акція, безкоштовний обід для учасників бойових дій, знижка для поліцейських та ДСНС у закладах, знижка для УБД магазин, військова знижка на одяг, акції для військовослужбовців супермаркет, знижка на автотовари для ЗСУ, спеціальна ціна для поліцейських магазин, товари для ДСНС знижка, безкоштовна стоматологія для УБД, знижка на ремонт авто для військових, безкоштовний абонемент у спортзал для ЗСУ, знижка на навчання для дітей учасників бойових дій, юридичні послуги для членів сімей загиблих безкоштовно, знижка на курси для поліцейських та рятувальників

# --- Autofill: промо-лексикон (bootstrap → miner → audit) ---
AUTOFILL_ENABLED=false
CORPUS_PATH=/data/corpus.jsonl
CORPUS_MAX_MB=50
PROMO_LEXICON_LEARNED_PATH=/data/promo_lexicon_learned.json
SNOWBALL_STATE_PATH=/data/snowball_state.json
MINER_MIN_DOMAIN_SUPPORT=3
MINER_MIN_LOGODDS=1.5
MINER_MAX_CANDIDATES_PER_RUN=50
CANDIDATES_PATH=/data/candidates.json
STOPLIST_PATH=/data/stoplist.json
